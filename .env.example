# --- Database ---
# Local dev: a file-backed libSQL DB is created automatically.
DATABASE_URL="file:./local.db"
# For Turso production: DATABASE_URL="libsql://<yours>.turso.io"
DATABASE_AUTH_TOKEN=""

# --- Session signing ---
# Generate with: openssl rand -base64 48
SESSION_SECRET="change-me-to-a-long-random-string-at-least-32-bytes"

# --- Initial bootstrap (used only by seed script) ---
SEED_DIRECTOR_EMAIL="director@pieperhs.test"
SEED_DIRECTOR_PASSWORD="change-me-on-first-login"
SEED_DRUM_MAJOR_EMAIL="hailey@pieperhs.test"
SEED_DRUM_MAJOR_PASSWORD="change-me-on-first-login"

# --- App URL (used in email links) ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Resend (email delivery). Leave empty to log emails to stdout only. ---
# RESEND_API_KEY=""
# RESEND_FROM="The Woodshed <noreply@your-domain.com>"

# --- PostHog (aggregate telemetry; leave empty for local dev). ---
# NEXT_PUBLIC_POSTHOG_KEY=""
# NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# --- Telemetry hashing salt. Change for production. ---
# TELEMETRY_SALT="replace-with-random-value"
